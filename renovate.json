{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["security:only-security-updates", ":semanticCommitScopeDisabled"],
  "ignorePresets": [":semanticPrefixFixDepsChoreOthers"],
  "semanticCommitType": "deps",
  "constraints": {
    "python": ">=3.10"
  },
  "constraintsFiltering": "strict",
  "git-submodules": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major",
        "minor",
        "patch",
        "digest",
        "pin",
        "rollback",
        "bump",
        "replacement",
        "lockFileMaintenance"
      ],
      "enabled": false
    },
    {
      "matchManagers": ["git-submodules", "pip_requirements", "pip-compile", "pep621", "poetry"],
      "enabled": true
    }
  ]
}
